        {
          "sn": "2.",
          "fields": [],
          "defs": [
            "To walk in a substance that yields to the feet; to move, sinking at each step, as in water, mud, sand, etc."
          ],
          "quotes": [
            "So eagerly the fiend . . . With head, hands, wings, or feet, pursues his way, And swims, or sinks, or wades, or creeps, or flies."
          ],
          "notes": [],
          "synonyms": []
        },
        {
          "sn": "3.",
          "fields": [],
          "defs": [
            "Hence, to move with difficulty or labor; to proceed slowly among objects or circumstances that constantly hinder or embarrass; as, to wade through a dull book."
          ],
          "quotes": [
            "And wades through fumes, and gropes his way.",
            "The king's admirable conduct has waded through all these difficulties."
          ],
          "notes": [],
          "synonyms": []
        }
