          "sn": "2.",
          "fields": [],
          "defs": [
            "Wanting the power of self-restraint; incontrolled; ungovernable; violent."
          ],
          "quotes": [
            "Impotent of tongue, her silence broke."
          ],
          "notes": [],
          "synonyms": []
        },
