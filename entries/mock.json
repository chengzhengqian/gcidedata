          "fields": [],
          "defs": [
            "To treat with scorn or contempt; to deride."
          ],
          "quotes": [
            "Elijah mocked them, and said, Cry aloud.",
            "Let not ambition mock their useful toil."
          ],
          "notes": [],
          "synonyms": []
        },
