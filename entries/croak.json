          "synonyms": []
        },
        {
          "sn": "2.",
          "fields": [],
          "defs": [
            "To complain; especially, to grumble; to forebode evil; to utter complaints or forebodings habitually."
          ],
          "quotes": [
            "Marat . . . croaks with reasonableness."
          ],
