          "fields": [],
          "defs": [
            "Lovable; amiable; having qualities of any kind which excite, or are fitted to excite, love or friendship."
          ],
          "quotes": [
            "A most lovely gentlemanlike man."
          ],
          "notes": [],
          "synonyms": []
        },
