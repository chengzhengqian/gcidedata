HEADWORD: Condylome
<hw>Con"dy*lome</hw> <pr>(-l⟦omac⟧m)</pr> }</mhw>, <pos>n.</pos>;
<plu><it>pl.</it> <plw>Condylomata</plw> <pr>(#)</pr> <it>or</it>
