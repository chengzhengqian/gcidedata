HEADWORD: Adversity
<hw>Ad*ver"si*ty</hw> <pr>(<?/)</pr>, <pos>n.</pos>; <plu><it>pl.</it>
<plw>Adversities</plw> <pr>(<?/)</pr>.</plu> <ety>[OE.
<ets>adversite</ets>, F. <ets>adversit⟦eacute⟧</ets>, fr. L.
<ets>adversitas</ets>.]</ety> <sn>1.</sn> <def>Opposition;
