          "fields": [],
          "defs": [
            "Transmitting light; clear; transparent."
          ],
          "quotes": [
            "From the brightest wines He 'd turn abhorrent."
          ],
          "notes": [],
          "synonyms": []
        },
        {
          "sn": "3.",
          "fields": [],
          "defs": [
