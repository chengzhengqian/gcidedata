      "senses": [
        {
          "sn": "1.",
          "fields": [],
          "defs": [
            "To press, force, or drive, particularly in filling, or in thrusting one thing into another; to stuff; to crowd; to fill to superfluity; as, to cram anything into a basket; to cram a room with people."
          ],
          "quotes": [
            "Their storehouses crammed with grain.",
            "He will cram his brass down our throats."
          ],
          "notes": [],
          "synonyms": []
        },
        {
          "sn": "2.",
          "fields": [],
          "defs": [
            "To fill with food to satiety; to stuff."
          ],
          "quotes": [
            "Children would be freer from disease if they were not crammed so much as they are by fond mothers.",
            "Cram us with praise, and make us As fat as tame things."
          ],
          "notes": [],
          "synonyms": []
        },
        {
          "sn": "3.",
          "fields": [],
          "defs": [
            "To put hastily through an extensive course of memorizing or study, as in preparation for an examination; as, a pupil is crammed by his tutor."
          ],
          "quotes": [],
          "notes": [],
          "synonyms": []
        }
      ]
