          "sn": "2.",
          "fields": [],
          "defs": [
            "The person who is substituted or deputed to act or vote for another."
          ],
          "quotes": [
            "Every peer . . . may make another lord of parliament his proxy, to vote for him in his absence."
          ],
          "notes": [],
          "synonyms": []
        },
