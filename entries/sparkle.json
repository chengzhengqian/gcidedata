          "fields": [],
          "defs": [
            "To manifest itself by, or as if by, emitting sparks; to glisten; to flash."
          ],
          "quotes": [
            "I see bright honor sparkle through your eyes."
          ],
          "notes": [],
          "synonyms": []
        },
