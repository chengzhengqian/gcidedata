          "fields": [],
          "defs": [
            "To take for granted, or without proof; to suppose as a fact; to suppose or take arbitrarily or tentatively."
          ],
          "quotes": [
            "The consequences of assumed principles."
          ],
          "notes": [],
          "synonyms": []
        },
        {
